# Required
POSTGRES_PASSWORD=changeme
REDIS_PASSWORD=changeme
SECRET_KEY=generate-a-32-char-secret-here

# LLM Provider: ollama | azure | bedrock
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:70b

# Azure OpenAI (if LLM_PROVIDER=azure)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# AWS Bedrock (if LLM_PROVIDER=bedrock)
# AWS_BEDROCK_REGION=eu-west-2
# AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Frontend
NEXT_PUBLIC_API_URL=https://your-domain.internal

# TLS (optional, for nginx)
# TLS_CERT_PATH=/etc/ssl/your-certs

ENVIRONMENT=production
